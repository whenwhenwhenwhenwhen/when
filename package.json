{
  "name": "when",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "concurrently -n convex,vite -c cyan,magenta \"convex dev\" \"vite\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "convex": "convex dev",
    "convex:deploy": "convex deploy",
    "dev:design": "vite --config vite.config.mock.ts",
    "docker:build": "docker buildx build --platform linux/amd64,linux/arm64 -t ghcr.io/whenwhenwhenwhenwhen/when:latest --push .",
    "docker:push": "pnpm docker:build",
    "docker:deploy": "pnpm docker:build"
  },
  "dependencies": {
    "convex": "^1.41.0",
    "luxon": "3.7.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.0.1"
  },
  "devDependencies": {
    "@types/luxon": "3.7.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "typescript": "~6.0.3",
    "vite": "8.0.16"
  }
}
